# Copy this file to .env and fill in real values. .env is gitignored.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=MyLm
MONGODB_DB=mylm
MONGO_UN=<user>
MONGO_PW=<password>
BOOKMIND_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
BOOKMIND_VECTOR_INDEX=vs_books_embedding